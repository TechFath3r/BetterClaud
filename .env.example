# BetterClaud Configuration
# Copy to ~/.config/betterclaud/.env and edit as needed.

# LanceDB storage (local directory)
# BETTERCLAUD_LANCEDB_PATH=~/.local/share/betterclaud/lancedb

# Ollama settings (local)
# BETTERCLAUD_OLLAMA_URL=http://localhost:11434
# BETTERCLAUD_EMBED_MODEL=nomic-embed-text
# BETTERCLAUD_EMBED_DIM=768

# Obsidian vault path (leave empty to disable vault features)
# BETTERCLAUD_VAULT_PATH=/path/to/your/obsidian/vault

# Session log subdirectory within vault
# BETTERCLAUD_VAULT_SESSION_DIR=Claude/sessions

# LanceDB table names
# BETTERCLAUD_MEMORY_TABLE=memories
# BETTERCLAUD_VAULT_TABLE=obsidian_vault

# ChromaDB knowledge base (optional — leave empty to disable)
# BETTERCLAUD_CHROMADB_PATH=
# BETTERCLAUD_CHROMADB_COLLECTION=default

# Context profiles directory (optional — leave empty to disable)
# BETTERCLAUD_CONTEXT_DIR=
